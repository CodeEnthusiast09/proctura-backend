{
  "info": {
    "name": "Proctura Backend",
    "description": "API collection for Proctura — multitenancy online coding exam platform.\n\nGroups follow the role model: super_admin, school_admin (view-only on academic content), lecturer (write), student (exam-only). Tenant-scoped requests need the X-Tenant-Subdomain header (or a real subdomain in production); /auth and /me work without it.",
    "_postman_id": "proctura-backend-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "tenant_subdomain", "value": "unilag", "type": "string" },
    { "key": "tenant_id", "value": "", "type": "string" },
    { "key": "course_id", "value": "", "type": "string" },
    { "key": "exam_id", "value": "", "type": "string" },
    { "key": "question_id", "value": "", "type": "string" },
    { "key": "test_case_id", "value": "", "type": "string" },
    { "key": "submission_id", "value": "", "type": "string" },
    { "key": "answer_id", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "student_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  if (res.data.user && res.data.user.subdomain) {",
                  "    pm.collectionVariables.set('tenant_subdomain', res.data.user.subdomain);",
                  "  }",
                  "  console.log('Token saved:', res.data.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@proctura.com\",\n  \"password\": \"Admin@123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "`identifier` accepts an email (any role) or a matric number (students only). Auto-detected by the presence of an `@` character.",
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@unilag.edu\",\n  \"password\": \"Student@123\",\n  \"first_name\": \"Emeka\",\n  \"last_name\": \"Nwosu\",\n  \"matric_number\": \"CSC/2020/001\",\n  \"subdomain\": \"unilag\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lecturer@unilag.edu\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset_token_from_email>\",\n  \"new_password\": \"NewPass@456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] }
          }
        },
        {
          "name": "Accept Invite",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "  if (res.data.user && res.data.user.subdomain) {",
                  "    pm.collectionVariables.set('tenant_subdomain', res.data.user.subdomain);",
                  "  }",
                  "  console.log('Activated and signed in. Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<invite_token_from_email>\",\n  \"first_name\": \"Chidi\",\n  \"last_name\": \"Okeke\",\n  \"password\": \"Lecturer@789\"\n}"
            },
            "description": "Returns a JWT — invitee is auto-authenticated, no second login required.",
            "url": { "raw": "{{base_url}}/auth/accept-invite", "host": ["{{base_url}}"], "path": ["auth", "accept-invite"] }
          }
        }
      ]
    },
    {
      "name": "Profile (any role)",
      "description": "Self-service for the authenticated user. Mounted under /me — no tenant header required, so super_admin can use these too.",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Chidi\",\n  \"last_name\": \"Okeke\"\n}"
            },
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"OldPass@123\",\n  \"new_password\": \"NewPass@456\"\n}"
            },
            "url": { "raw": "{{base_url}}/me/change-password", "host": ["{{base_url}}"], "path": ["me", "change-password"] }
          }
        }
      ]
    },
    {
      "name": "Super Admin — Tenants",
      "item": [
        {
          "name": "Create Tenant (School)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.tenant) {",
                  "  pm.collectionVariables.set('tenant_id', res.data.tenant.id);",
                  "  pm.collectionVariables.set('tenant_subdomain', res.data.tenant.subdomain);",
                  "  console.log('Tenant ID saved:', res.data.tenant.id);",
                  "  console.log('Admin invite token:', res.data.admin && res.data.admin.invite_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"University of Lagos\",\n  \"subdomain\": \"unilag\",\n  \"admin_email\": \"admin@unilag.edu.ng\",\n  \"admin_first_name\": \"Chidi\",\n  \"admin_last_name\": \"Okeke\"\n}"
            },
            "url": { "raw": "{{base_url}}/admin/tenants", "host": ["{{base_url}}"], "path": ["admin", "tenants"] }
          }
        },
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/tenants?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "tenants"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"University of Lagos (Updated)\",\n  \"is_active\": true\n}"
            },
            "url": { "raw": "{{base_url}}/admin/tenants/{{tenant_id}}", "host": ["{{base_url}}"], "path": ["admin", "tenants", "{{tenant_id}}"] }
          }
        },
        {
          "name": "Bulk Activate / Deactivate Tenants",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\"{{tenant_id}}\"],\n  \"is_active\": false\n}"
            },
            "description": "Toggle is_active for multiple tenants at once. Pass the desired state.",
            "url": { "raw": "{{base_url}}/admin/tenants/bulk-active", "host": ["{{base_url}}"], "path": ["admin", "tenants", "bulk-active"] }
          }
        },
        {
          "name": "Recovery: Invite School Admin into Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"recovery-admin@unilag.edu.ng\",\n  \"first_name\": \"Aisha\",\n  \"last_name\": \"Bello\"\n}"
            },
            "description": "Used when both school admins of a tenant are unreachable. Capped at 2 active admins per tenant.",
            "url": { "raw": "{{base_url}}/admin/tenants/{{tenant_id}}/invite-admin", "host": ["{{base_url}}"], "path": ["admin", "tenants", "{{tenant_id}}", "invite-admin"] }
          }
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/admin/tenants/{{tenant_id}}", "host": ["{{base_url}}"], "path": ["admin", "tenants", "{{tenant_id}}"] }
          }
        }
      ]
    },
    {
      "name": "School Admin — Users",
      "description": "User management. school_admin role only — note the lecturer/student invite endpoints all live under this group.",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users?role=lecturer&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                { "key": "role", "value": "lecturer", "description": "school_admin | lecturer | student" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Invite Co-Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('user_id', res.data.id);",
                  "  console.log('Co-admin invite token:', res.data.invite_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"coadmin@unilag.edu.ng\",\n  \"first_name\": \"Aisha\",\n  \"last_name\": \"Bello\"\n}"
            },
            "description": "Capped at 2 active school admins per tenant. Returns 400 with `this school already has the maximum of 2 active admins` if exceeded.",
            "url": { "raw": "{{base_url}}/users/invite-admin", "host": ["{{base_url}}"], "path": ["users", "invite-admin"] }
          }
        },
        {
          "name": "Invite Lecturer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('user_id', res.data.id);",
                  "  console.log('Invite token:', res.data.invite_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lecturer@unilag.edu.ng\",\n  \"first_name\": \"Ngozi\",\n  \"last_name\": \"Adeyemi\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/invite-lecturer", "host": ["{{base_url}}"], "path": ["users", "invite-lecturer"] }
          }
        },
        {
          "name": "Invite Student (single)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('student_id', res.data.id);",
                  "  console.log('Student invite token:', res.data.invite_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"emeka@unilag.edu.ng\",\n  \"first_name\": \"Emeka\",\n  \"last_name\": \"Nwosu\",\n  \"matric_number\": \"CSC/2020/001\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/invite-student", "host": ["{{base_url}}"], "path": ["users", "invite-student"] }
          }
        },
        {
          "name": "Import Students (CSV)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "students.csv",
                  "description": "CSV with columns: email, first_name, last_name, matric_number"
                }
              ]
            },
            "url": { "raw": "{{base_url}}/users/import-students", "host": ["{{base_url}}"], "path": ["users", "import-students"] }
          }
        },
        {
          "name": "Update User (toggle active)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            },
            "description": "Last-admin protection: rejected with 400 if it would leave 0 active school_admins.",
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        },
        {
          "name": "Bulk Activate / Deactivate Users",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\"{{user_id}}\"],\n  \"is_active\": false\n}"
            },
            "description": "All-or-nothing: rejected with 400 if it would leave 0 active school_admins.",
            "url": { "raw": "{{base_url}}/users/bulk-active", "host": ["{{base_url}}"], "path": ["users", "bulk-active"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Shared Reads (any role within tenant)",
      "description": "Read-only endpoints accessible to all authenticated roles within a tenant.",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": {
              "raw": "{{base_url}}/courses?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List Exams",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": {
              "raw": "{{base_url}}/exams?course_id={{course_id}}&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["exams"],
              "query": [
                { "key": "course_id", "value": "{{course_id}}" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Exam",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/exams/{{exam_id}}", "host": ["{{base_url}}"], "path": ["exams", "{{exam_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Staff Reads (school_admin + lecturer)",
      "description": "Result and submission views shared between school_admin and lecturer.",
      "item": [
        {
          "name": "Get Exam Results",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/exams/{{exam_id}}/results", "host": ["{{base_url}}"], "path": ["exams", "{{exam_id}}", "results"] }
          }
        },
        {
          "name": "Get All Results (across exams)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": {
              "raw": "{{base_url}}/results?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["results"],
              "query": [
                { "key": "course_id", "value": "", "disabled": true },
                { "key": "exam_id", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true, "description": "in_progress | submitted | graded" },
                { "key": "search", "value": "", "disabled": true, "description": "name or matric" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Submission Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}"] }
          }
        },
        {
          "name": "List Course Enrollments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/courses/{{course_id}}/enrollments", "host": ["{{base_url}}"], "path": ["courses", "{{course_id}}", "enrollments"] }
          }
        }
      ]
    },
    {
      "name": "Lecturer — Courses",
      "item": [
        {
          "name": "Create Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('course_id', res.data.id);",
                  "  console.log('Course ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
