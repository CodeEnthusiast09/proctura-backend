    {
      "name": "Student — Exam Flow",
      "item": [
        {
          "name": "Get Available Exams",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "description": "Currently-active exams the student is enrolled in.",
            "url": { "raw": "{{base_url}}/exams/available", "host": ["{{base_url}}"], "path": ["exams", "available"] }
          }
        },
        {
          "name": "List My Submissions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/my-submissions", "host": ["{{base_url}}"], "path": ["my-submissions"] }
          }
        },
        {
          "name": "Start Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('submission_id', res.data.id);",
                  "  console.log('Submission ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/exams/{{exam_id}}/start", "host": ["{{base_url}}"], "path": ["exams", "{{exam_id}}", "start"] }
          }
        },
        {
          "name": "Get My Submission for Exam",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "description": "Used by the start page to detect a previously-started in-progress submission and offer Resume.",
            "url": { "raw": "{{base_url}}/exams/{{exam_id}}/my-submission", "host": ["{{base_url}}"], "path": ["exams", "{{exam_id}}", "my-submission"] }
          }
        },
        {
          "name": "Save Answer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question_id\": \"{{question_id}}\",\n  \"code\": \"def reverse_string(s):\\n    return s[::-1]\\nprint(reverse_string(input()))\"\n}"
            },
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/answer", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "answer"] }
          }
        },
        {
          "name": "Run Code (visible test cases)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question_id\": \"{{question_id}}\",\n  \"code\": \"def reverse_string(s):\\n    return s[::-1]\\nprint(reverse_string(input()))\"\n}"
            },
            "description": "Runs the code against the visible (non-hidden) test cases only. Does not affect the saved answer.",
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/run", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "run"] }
          }
        },
        {
          "name": "Get Upload Token (recording)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "description": "Returns a Cloudinary or MinIO signed upload token for the student's webcam recording.",
            "url": {
              "raw": "{{base_url}}/submissions/{{submission_id}}/upload-token?size=2097152",
              "host": ["{{base_url}}"],
              "path": ["submissions", "{{submission_id}}", "upload-token"],
              "query": [
                { "key": "size", "value": "2097152", "description": "blob size in bytes (router uses this to pick provider)" }
              ]
            }
          }
        },
        {
          "name": "Attach Recording URL",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recording_url\": \"https://res.cloudinary.com/.../proctura/recordings/recording-abc.webm\"\n}"
            },
            "description": "Called after the browser uploads the webm directly to Cloudinary/MinIO with the signed token.",
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/recording", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "recording"] }
          }
        },
        {
          "name": "Submit Exam",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "description": "Marks submission as submitted and enqueues grading via asynq. Poll /submissions/:id/result for the score.",
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/submit", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "submit"] }
          }
        },
        {
          "name": "Get Result",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "description": "If the lecturer hasn't released results, total/max score and per-answer scores come back zeroed.",
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/result", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "result"] }
          }
        },
        {
          "name": "Log Violation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"tab_switch\"\n}"
            },
            "description": "Reasons: tab_switch | window_switch | fullscreen_exit | copy | paste. Auto-submits after 3.",
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/violation", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "violation"] }
          }
        }
      ]
    }
  ]
}
