              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/exams/available", "host": ["{{base_url}}"], "path": ["exams", "available"] }
          }
        },
        {
          "name": "Start Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('submission_id', res.data.id);",
                  "  console.log('Submission ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/exams/{{exam_id}}/start", "host": ["{{base_url}}"], "path": ["exams", "{{exam_id}}", "start"] }
          }
        },
        {
          "name": "Save Answer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question_id\": \"{{question_id}}\",\n  \"code\": \"def reverse_string(s):\\n    return s[::-1]\\nprint(reverse_string(input()))\"\n}"
            },
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/answer", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "answer"] }
          }
        },
        {
          "name": "Submit Exam",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/submit", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "submit"] }
          }
        },
        {
          "name": "Get Result",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/result", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "result"] }
          }
        },
        {
          "name": "Log Violation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-Subdomain", "value": "{{tenant_subdomain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"tab_switch\"\n}"
            },
            "url": { "raw": "{{base_url}}/submissions/{{submission_id}}/violation", "host": ["{{base_url}}"], "path": ["submissions", "{{submission_id}}", "violation"] }
          }
        }
      ]
    }
  ]
}
