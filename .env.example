# Server
PORT=8080

# Database (use DATABASE_URL or individual fields)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=proctura_db

# JWT
JWT_SECRET=
JWT_EXPIRATION=24h

# Judge0 via RapidAPI
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Proctura <noreply@proctura.com>

# Cloudinary (primary recording storage — files < 100 MB)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MinIO (fallback recording storage — files >= 100 MB)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=proctura
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=

# Email — Resend primary, SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# App
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
